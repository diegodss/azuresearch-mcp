# Provider
SEARCH_PROVIDER=azure
MOCK_SEARCH_DATA_PATH=config/mock_search_data.json

# Queue + Job Store
QUEUE_BACKEND=local
JOB_DB_PATH=data/jobs.db
WORKER_POLL_SECONDS=20
WORKER_RETRY_DELAY_SECONDS=30

# Azure Service Bus (if QUEUE_BACKEND=servicebus)
AZURE_SERVICEBUS_CONNECTION_STRING=
AZURE_SERVICEBUS_QUEUE_NAME=ingestion-jobs

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://yourservice.search.windows.net
AZURE_SEARCH_KEY=your-key

# Auth
AUTH_MODE=token
MCP_API_KEY=your-secret-token

# Entra ID (if AUTH_MODE=entra)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# Ingestion - SharePoint
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=

# Ingestion - Video (choose one)
WHISPER_MODEL=base
AZURE_VIDEO_INDEXER_KEY=
AZURE_VIDEO_INDEXER_ACCOUNT_ID=
AZURE_VIDEO_INDEXER_LOCATION=trial
